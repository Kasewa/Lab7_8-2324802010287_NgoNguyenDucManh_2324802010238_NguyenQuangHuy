@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col s12 m6 offset-m3">
            <div class="card" style="margin-top: 50px; padding: 20px;">
                <div class="card-content">
                    <span class="card-title">Reset Password</span>
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors red-text"></div>
                        <input asp-for="Input.Code" type="hidden" />
                        <div class="row">
                            <div class="input-field col s12">
                                <i class="material-icons prefix">email</i>
                                <input asp-for="Input.Email" id="Input_Email" class="validate" type="email" />
                                <label for="Input_Email">Email</label>
                                <span asp-validation-for="Input.Email" class="red-text helper-text"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-field col s12">
                                <i class="material-icons prefix">lock</i>
                                <input asp-for="Input.Password" id="Input_Password" class="validate" type="password" />
                                <label for="Input_Password">New Password</label>
                                <span asp-validation-for="Input.Password" class="red-text helper-text"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-field col s12">
                                <i class="material-icons prefix">lock_outline</i>
                                <input asp-for="Input.ConfirmPassword" id="Input_ConfirmPassword" class="validate" type="password" />
                                <label for="Input_ConfirmPassword">Confirm Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="red-text helper-text"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col s12">
                                <button type="submit" class="btn waves-effect waves-light blue-grey darken-1 col s12">
                                    Reset Password <i class="material-icons right">lock</i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
